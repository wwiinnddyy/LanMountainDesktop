<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="LanMountainDesktop.Views.DesktopWidgetWindow"
        Title="Desktop Component"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="Transparent"
        Topmost="False"
        SizeToContent="WidthAndHeight"
        TransparencyLevelHint="Transparent"
        RenderOptions.BitmapInterpolationMode="HighQuality"
        CanResize="False">

    <Grid x:Name="RootGrid"
          ClipToBounds="True">
        <Border x:Name="ComponentContainer"
                Background="Transparent"
                CornerRadius="0"
                ClipToBounds="False">
            <!-- Component control will be injected here -->
        </Border>

        <!-- Edit mode border overlay -->
        <Border x:Name="EditModeBorder"
                BorderThickness="2"
                BorderBrush="#0078D4"
                Background="Transparent"
                CornerRadius="0"
                IsVisible="False"
                IsHitTestVisible="False" />

        <!-- Resize adorner will be added programmatically -->
    </Grid>
</Window>
