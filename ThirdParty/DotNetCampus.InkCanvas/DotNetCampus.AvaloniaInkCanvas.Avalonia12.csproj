<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>DotNetCampus.AvaloniaInkCanvas</AssemblyName>
    <RootNamespace>DotNetCampus.Inking</RootNamespace>
    <IsPackable>false</IsPackable>
    <DefaultItemExcludes>$(DefaultItemExcludes);src/**/bin/**;src/**/obj/**</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Skia" />
    <PackageReference Include="DotNetCampus.Logger" />
    <PackageReference Include="DotNetCampus.Numerics.Geometry" />
    <PackageReference Include="SkiaSharp" />
  </ItemGroup>
</Project>
